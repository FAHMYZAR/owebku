<IfModule mod_rewrite.c>
    RewriteEngine On

    # Jika file/folder asli ada, langsung akses
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Semua route diarahkan ke front controller
    RewriteRule ^ index.php [L]
</IfModule>

Options -Indexes
