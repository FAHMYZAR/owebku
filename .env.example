# Copy this file to .env on the server and fill in real values.
# Never commit .env or paste real secrets into chat/Git.

APP_ENV=production
APP_DEBUG=0
APP_URL=https://owebku.site

DB_HOST=mysql
DB_PORT=3306
DB_NAME=dbowebku
DB_USER=owebkuuser
DB_PASSWORD=replace-with-a-long-random-password

# Optional PHP session settings
SESSION_COOKIE_NAME=owebku_session
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
