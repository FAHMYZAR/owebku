# ========================
# Owebku .gitignore
# ========================

# --- Dependencies ---
node_modules/

# --- Environment / Config ---
.env
.env.*
!.env.example

# --- Storage (runtime/user data) ---
storage/quarantine/*
storage/sessions/*
storage/workspaces/*
storage/logs/*
!storage/quarantine/.gitkeep
!storage/sessions/.gitkeep
!storage/workspaces/.gitkeep
!storage/logs/.gitkeep

# --- Published Sites (user output) ---
sites/*
!sites/.gitkeep

# --- Local agent docs ---
AGENTS.md

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
Thumbs.db
Desktop.ini
.DS_Store

# --- PHP ---
*.phar
composer.lock

docs-makalah
docs-uml